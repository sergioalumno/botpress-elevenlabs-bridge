# ============================================================
# CONFIGURACIÓN DEL SERVIDOR MIDDLEWARE
# Copia este archivo como .env y rellena los valores
# ============================================================

# Puerto del servidor (por defecto 3000)
PORT=3000

# ============================================================
# TWILIO
# Encuentra estos valores en https://console.twilio.com/
# ============================================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Tu número de Twilio (el que hace las llamadas)
TWILIO_PHONE_FROM=+1XXXXXXXXXX

# Tu número personal (al que quieres que te llame)
TWILIO_PHONE_TO=+34XXXXXXXXX

# ============================================================
# ELEVENLABS
# Encuentra el Voice ID en https://elevenlabs.io/ → Voices
# ============================================================
ELEVENLABS_VOICE_ID=TU_VOICE_ID_DE_ELEVENLABS

# ============================================================
# BOTPRESS
# Encuentra el Webhook ID en Botpress Studio → Integraciones → Chat
# ============================================================
BOTPRESS_WEBHOOK_ID=TU_WEBHOOK_ID_DE_BOTPRESS

# ============================================================
# URL PÚBLICA DEL SERVIDOR
# Cuando uses ngrok: la URL wss:// que te da ngrok
# Cuando despliegues en Render: la URL de tu servicio
# Ejemplo ngrok: wss://abc123.ngrok-free.dev
# Ejemplo Render: wss://mi-servicio.onrender.com
# Ejemplo Railway: wss://mi-servicio.up.railway.app
# ============================================================
SERVER_PUBLIC_URL=wss://TU-URL-PUBLICA
